# ============================================================================
# Lucifex — Example Environment Variables
# ============================================================================
# Copy this file to .env (which is gitignored) and fill in real values for
# local development. Never commit a .env file with real credentials.
#
# In production, these values are injected by the deployment platform; the
# .env file is for local development only.
# ============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Connection string for the Lucifex Postgres database. The +asyncpg driver
# is required because the application uses async sessions.
LUCIFEX_DATABASE_URL=postgresql+asyncpg://lucifex:lucifex@localhost:5432/lucifex_dev

# ----------------------------------------------------------------------------
# Encryption
# ----------------------------------------------------------------------------
# Symmetric encryption key used to encrypt OAuth tokens and other secrets
# at rest. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LUCIFEX_ENCRYPTION_KEY=change-me-generate-a-real-key

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
LUCIFEX_ENV=development
LUCIFEX_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Future — populated as features are added
# ----------------------------------------------------------------------------
# LLM and video provider API keys, OAuth client IDs, Sentry DSN, etc.
# These are added per-feature in later chunks.
